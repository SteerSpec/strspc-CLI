  "rules": [
    {
      "id": "CMD-001",
      "revision": 0,
      "state": "D",
      "body": "Every command MUST declare both Short and Long descriptions in its cobra.Command definition.",
      "added_by": "@pleberre",
      "added_at": "2026-03-25",
      "supersedes": null
    },
    {
      "id": "CMD-002",
      "revision": 0,
      "state": "D",
      "body": "Commands that return errors MUST set SilenceUsage: true and SilenceErrors: true to suppress cobra's default error printing.",
      "added_by": "@pleberre",
      "added_at": "2026-03-25",
      "supersedes": null
    },
    {
      "id": "CMD-003",
      "revision": 0,
      "state": "D",
      "body": "Command output MUST be written via cmd.OutOrStdout() and cmd.ErrOrStderr() to support testing with captured output buffers.",
      "added_by": "@pleberre",
      "added_at": "2026-03-25",
      "supersedes": null
    }
  ],
  "notes": []
}
